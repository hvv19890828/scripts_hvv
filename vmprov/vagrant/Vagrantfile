# -*- mode: ruby -*-
# vi:set ft=ruby sw=2 ts=2 sts=2:
NODES = 3
NODES_START = 1
BRIF = "wlp2s0"
XRAM = 2048
XCPU = 2
IP_NW = "192.168.6."
#"enx000ec79ecb52""wlp2s0"
Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/bionic64"
  config.vm.box_check_update = true
#  config.vm.base_mac = nil
  (NODES_START..NODES).each do |i|
      config.vm.define "host#{i}" do |host|
        host.vm.provider "virtualbox" do |vb|
            vb.name = "host#{i}"
            vb.memory = XRAM
            vb.cpus = XCPU
        end
        host.vm.hostname = "host#{i}"
        host.vm.network :private_network, ip: IP_NW + "#{30 + i}", auto_correct: true
#, virtualbox__intnet: true
        host.vm.network "forwarded_port", guest: 22, host: "#{54320 +i}", auto_correct: true
#        host.vm.network "public_network", :ip => IP_NW + "#{210 + i}", :netmask => '255.255.255.0', :bridge => BRIF,
        host.vm.network "forwarded_port", guest: "#{54320 + NODES  + i}", host: "#{54320 + NODES  + i}", auto_correct: true
#        host.vm.provision "shell",
#                run: "always",
#                inline: "route add default gw 192.168.0.1"
#Custom Port Forwarding

        host.vm.network "forwarded_port", guest:80, host: "#{54320 + (NODES * 2) + i}", auto_correct: true 
        host.vm.network "forwarded_port", guest:443, host: "#{54320 + (NODES * 3) + i}", auto_correct: true
        host.vm.network "forwarded_port", guest:5060, host: "#{54320 + (NODES * 4) + i}", auto_correct: true
        host.vm.network "forwarded_port", guest:5160, host: "#{54320 + (NODES * 5) + i}", auto_correct: true
        host.vm.network "forwarded_port", guest:4445, host: "#{54320 + (NODES * 6) + i}", auto_correct: true        
        host.vm.network "forwarded_port", guest:18001, host: "#{54320 + (NODES * 7) + i}", auto_correct: true

#Custom Port Forwarding
        host.vm.provision "setup-dns", type: "shell", :path => "ubuntu/update-dns.sh"
        host.vm.provision "ssh-setup", type: "shell", :path => "ubuntu/ssh-setup.sh"
      end
  end
end
